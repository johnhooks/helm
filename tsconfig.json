{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@helm/lcars": ["resources/packages/lcars/src"],
            "@helm/lcars/*": ["resources/packages/lcars/src/*"],
            "@helm/bridge": ["resources/packages/bridge/src"],
            "@helm/bridge/*": ["resources/packages/bridge/src/*"],
            "@helm/astrometric": ["resources/packages/astrometric/src"],
            "@helm/astrometric/*": ["resources/packages/astrometric/src/*"],
            "@helm/benchmark": ["resources/packages/benchmark/src"],
            "@helm/benchmark/*": ["resources/packages/benchmark/src/*"],
            "@helm/datacore": ["resources/packages/datacore/src"],
            "@helm/datacore/*": ["resources/packages/datacore/src/*"],
            "@helm/errors": ["resources/packages/errors/src"],
            "@helm/errors/*": ["resources/packages/errors/src/*"],
            "@helm/cache": ["resources/packages/cache/src"],
            "@helm/cache/*": ["resources/packages/cache/src/*"],
            "@helm/types": ["resources/packages/types/src"],
            "@helm/types/*": ["resources/packages/types/src/*"]
        }
    },
    "include": [
        "global.d.ts",
        "resources/packages/**/*.ts",
        "resources/packages/**/*.tsx",
        "tests-e2e/**/*.ts",
        "vitest.setup.ts"
    ],
    "exclude": [
        "node_modules",
        "build",
        "vendor"
    ]
}
