{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@helm/actions": ["resources/packages/actions/src"],
            "@helm/actions/*": ["resources/packages/actions/src/*"],
            "@helm/lcars": ["resources/packages/lcars/src"],
            "@helm/lcars/*": ["resources/packages/lcars/src/*"],
            "@helm/bridge": ["resources/packages/bridge/src"],
            "@helm/bridge/*": ["resources/packages/bridge/src/*"],
            "@helm/astrometric": ["resources/packages/astrometric/src"],
            "@helm/astrometric/*": ["resources/packages/astrometric/src/*"],
            "@helm/benchmark": ["resources/packages/benchmark/src"],
            "@helm/benchmark/*": ["resources/packages/benchmark/src/*"],
            "@helm/datacore": ["resources/packages/datacore/src"],
            "@helm/datacore/*": ["resources/packages/datacore/src/*"],
            "@helm/errors": ["resources/packages/errors/src"],
            "@helm/errors/*": ["resources/packages/errors/src/*"],
            "@helm/nav": ["resources/packages/nav/src"],
            "@helm/nav/*": ["resources/packages/nav/src/*"],
            "@helm/types": ["resources/packages/types/src"],
            "@helm/types/*": ["resources/packages/types/src/*"],
            "@helm/ui": ["resources/packages/ui/src"],
            "@helm/ui/*": ["resources/packages/ui/src/*"],
            "@helm/admin-settings": ["resources/packages/admin-settings/src"],
            "@helm/admin-settings/*": ["resources/packages/admin-settings/src/*"],
            "@helm/router": ["resources/packages/router/src"],
            "@helm/router/*": ["resources/packages/router/src/*"],
            "@helm/ships": ["resources/packages/ships/src"],
            "@helm/ships/*": ["resources/packages/ships/src/*"],
            "@helm/core": ["resources/packages/core/src"],
            "@helm/core/*": ["resources/packages/core/src/*"]
        }
    },
    "include": [
        "global.d.ts",
        "resources/packages/**/*.ts",
        "resources/packages/**/*.tsx",
        "tests-e2e/**/*.ts",
        "vitest.setup.ts"
    ],
    "exclude": [
        "node_modules",
        "build",
        "vendor"
    ]
}
