{
    "name": "@okaywp/helm",
    "version": "0.1.0",
    "description": "Starship Operating System built on WordPress",
    "private": true,
    "workspaces": [
        "resources/packages/*"
    ],
    "scripts": {
        "build": "wp-scripts build",
        "release": "bin/build-release.sh",
        "release:prerelease": "bin/build-release.sh --with-commit-hash",
        "dev": "wp-scripts start",
        "lint:js": "wp-scripts lint-js resources/packages",
        "lint:fix": "wp-scripts lint-js resources/packages --fix",
        "format": "wp-scripts format resources/packages",
        "check-types": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report artifacts/playwright-report",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build -o artifacts/storybook",
        "wb": "bun resources/packages/workbench/src/cli.ts",
        "bench": "bun ./resources/packages/benchmark/benchmarks/nodes.ts",
        "bench:nodes": "bun ./resources/packages/benchmark/benchmarks/nodes.ts",
        "bench:compare": "bun ./resources/packages/benchmark/benchmarks/compare.ts",
        "prepare": "husky install"
    },
    "dependencies": {
        "@tanstack/react-router": "^1.159.4",
        "@wordpress/api-fetch": "^7.0.0",
        "@wordpress/components": "^28.0.0",
        "@wordpress/compose": "^7.0.0",
        "@wordpress/data": "^10.0.0",
        "@wordpress/element": "^6.0.0",
        "@wordpress/hooks": "^4.0.0",
        "@wordpress/i18n": "^5.0.0",
        "@wordpress/icons": "^10.0.0",
        "@wordpress/notices": "^5.0.0",
        "@wordpress/url": "^4.0.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-error-boundary": "^6.1.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.0",
        "@storybook/react-vite": "^10.2.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bun": "^1.3.8",
        "@types/node": "^20.10.0",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "@vitejs/plugin-react": "^4.3.0",
        "@vitest/coverage-v8": "^2.0.0",
        "@wordpress/browserslist-config": "^6.39.0",
        "@wordpress/e2e-test-utils-playwright": "^1.38.0",
        "@wordpress/eslint-plugin": "^24.1.0",
        "@wordpress/scripts": "^28.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.5.4",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "happy-dom": "^14.0.0",
        "husky": "^8.0.3",
        "lint-staged": "^15.5.2",
        "prettier": "^3.1.1",
        "sass": "^1.69.0",
        "storybook": "^10.2.0",
        "typescript": "^5.3.0",
        "vite": "^7.3.1",
        "vitest": "^2.0.0"
    }
}
