<?xml version="1.0"?>
<ruleset name="Helm">
    <description>PSR-12 with WordPress security sniffs for Helm</description>

    <!-- Scan these files -->
    <file>./src</file>
    <file>./helm.php</file>

    <!-- Exclude vendor and build artifacts -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>

    <!-- Show colors and progress -->
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Use PSR-12 as the base -->
    <rule ref="PSR12">
        <!-- Plugin bootstrap files need side effects -->
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
    </rule>

    <!-- WordPress security and best practices -->
    <rule ref="WordPress.Security">
        <!-- Exceptions don't need escaping -->
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
    </rule>
    <rule ref="WordPress.DB">
        <!-- We use %i placeholder for table names (WP 6.2+) which PHPCS doesn't recognize -->
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
        <exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
    </rule>
    <rule ref="WordPress.DateTime.RestrictedFunctions"/>
    <rule ref="WordPress.PHP.DevelopmentFunctions"/>
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions"/>
    <rule ref="WordPress.PHP.NoSilencedErrors"/>
    <rule ref="WordPress.WP.AlternativeFunctions"/>
    <rule ref="WordPress.WP.DeprecatedFunctions"/>
    <rule ref="WordPress.WP.DeprecatedClasses"/>
    <rule ref="WordPress.WP.DeprecatedParameters"/>

    <!-- Modern PHP: require short array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Modern PHP: dirname(__DIR__) instead of dirname(dirname(__FILE__)) -->
    <rule ref="Modernize.FunctionCalls.Dirname"/>

    <!-- Tests use snake_case method names (PHPUnit convention) -->
    <rule ref="PSR1.Methods.CamelCapsMethodName.NotCamelCaps">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- Tests: _before() is a Codeception lifecycle method -->
    <rule ref="PSR2.Methods.MethodDeclaration.Underscore">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- Tests don't need WP security rules -->
    <rule ref="WordPress.Security">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.DB">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
</ruleset>
