{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.okaywp.com/resources/schemas/shield.json",
  "title": "Shield System Types",
  "description": "Schema for shield component seed data. Shields provide damage absorption and regeneration.",
  "type": "object",
  "required": ["items"],
  "properties": {
    "$schema": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "https://helm.okaywp.com/resources/schemas/system-type.json" },
          {
            "type": "object",
            "properties": {
              "type": { "const": "shield" },
              "rate": {
                "type": "number",
                "minimum": 0,
                "description": "Shield regeneration rate (units/hour)."
              },
              "capacity": {
                "type": "number",
                "minimum": 0,
                "description": "Maximum shield capacity."
              }
            },
            "required": ["rate", "capacity"]
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
